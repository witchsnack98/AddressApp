# ========================
# Root-level .gitignore
# ========================

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# ========================
# Backend (NestJS)
# ========================
backend/node_modules/
backend/dist/
backend/.env
backend/.env.*
backend/coverage/
backend/*.tsbuildinfo

# ========================
# Frontend (Next.js)
# ========================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.env
frontend/.env.*
frontend/coverage/
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# ========================
# Docker / DB
# ========================
# Keep docker-compose.yml but ignore any local override
docker-compose.override.yml
